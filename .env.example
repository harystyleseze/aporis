# LI.FI Composer API Key (optional — increases rate limits)
# Get yours at https://portal.li.fi/
NEXT_PUBLIC_LIFI_API_KEY=

# WalletConnect Project ID (optional — enables wallet modal)
# Get yours at https://cloud.walletconnect.com/
NEXT_PUBLIC_WC_PROJECT_ID=

# LLM Configuration (any OpenAI-compatible provider)
# Default: Groq free tier (https://console.groq.com/)
# Also works with: OpenAI, Together, Ollama, Fireworks, etc.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=
